{
    "dataRoles": [
        {
            "displayName": "Values",
            "name": "measure",
            "kind": "Measure",
            "description": "Numeric field to plot as histogram"
        },
        {
            "displayName": "Detail (rows)",
            "name": "category",
            "kind": "Grouping",
            "description": "Optional category for row-level data"
        }
    ],
    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "for": {
                        "in": "category"
                    },
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 30000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "measure"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "objects": {
        "histogram": {
            "displayName": "Histogram",
            "properties": {
                "bins": {
                    "displayName": "Number of bins (Pro)",
                    "description": "Number of bins. Free tier is fixed at 10. Upgrade to Pro for 2–100.",
                    "type": { "numeric": true }
                },
                "trimLower": {
                    "displayName": "Lower trim % (Pro)",
                    "description": "Trim bottom N% of values as outliers. Pro only.",
                    "type": { "numeric": true }
                },
                "trimUpper": {
                    "displayName": "Upper trim % (Pro)",
                    "description": "Trim top N% of values as outliers. Pro only.",
                    "type": { "numeric": true }
                },
                "barColor": {
                    "displayName": "Bar color (Pro)",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "barOpacity": {
                    "displayName": "Bar opacity % (Pro)",
                    "type": { "numeric": true }
                },
                "borderColor": {
                    "displayName": "Border color (Pro)",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "borderWidth": {
                    "displayName": "Border width (Pro)",
                    "type": { "numeric": true }
                },
                "barGap": {
                    "displayName": "Bar gap px (Pro)",
                    "type": { "numeric": true }
                }
            }
        },
        "axes": {
            "displayName": "Axes",
            "properties": {
                "axisColor": {
                    "displayName": "Axis text color",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "gridColor": {
                    "displayName": "Grid color",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "fontSize": {
                    "displayName": "Font size",
                    "type": { "formatting": { "fontSize": true } }
                },
                "showXLabel": {
                    "displayName": "Show X label",
                    "type": { "bool": true }
                },
                "showYLabel": {
                    "displayName": "Show Y label",
                    "type": { "bool": true }
                }
            }
        },
        "statistics": {
            "displayName": "Statistics",
            "properties": {
                "showMean": {
                    "displayName": "Show mean line",
                    "type": { "bool": true }
                },
                "meanColor": {
                    "displayName": "Mean line color",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "showMedian": {
                    "displayName": "Show median line",
                    "type": { "bool": true }
                },
                "medianColor": {
                    "displayName": "Median line color",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "showNormal": {
                    "displayName": "Normal curve (Pro)",
                    "description": "Overlay a normal distribution curve. Pro only.",
                    "type": { "bool": true }
                },
                "normalColor": {
                    "displayName": "Normal curve color (Pro)",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "showStats": {
                    "displayName": "Stats panel (Pro)",
                    "description": "Show n, mean, median, σ, min, max panel. Pro only.",
                    "type": { "bool": true }
                },
                "statsColor": {
                    "displayName": "Stats text color (Pro)",
                    "type": { "fill": { "solid": { "color": true } } }
                }
            }
        },
        "valueLabels": {
            "displayName": "Value labels (Pro)",
            "properties": {
                "show": {
                    "displayName": "Show",
                    "type": { "bool": true }
                },
                "fontSize": {
                    "displayName": "Font size",
                    "type": { "formatting": { "fontSize": true } }
                },
                "color": {
                    "displayName": "Color",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "showPercent": {
                    "displayName": "Show percent",
                    "type": { "bool": true }
                }
            }
        }
    },
    "supportsHighlight": true,
    "supportsSynchronizingFilterState": true,
    "supportsLandingPage": true,
    "supportsKeyboardFocus": true,
    "supportsMultiVisualSelection": true,
    "sorting": {
        "default": {}
    },
    "privileges": []
}
